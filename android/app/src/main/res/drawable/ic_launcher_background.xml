<!--
  ic_launcher_background.xml
  AccessEye

  Adaptive launcher icon background layer. Full-bleed linear gradient matching the
  iOS icon-1024.png: teal (top-left) -> royal blue -> purple (bottom-right).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0" android:color="#FF1BA2B4" />
                <item android:offset="0.55" android:color="#FF2C55A8" />
                <item android:offset="1" android:color="#FF5C3EA0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
