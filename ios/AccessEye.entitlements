<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Gemma 3n E2B is a ~3.4 GB model; loading + running it on-device exceeds
	     the default per-app memory cap, so iOS would jetsam-kill the app. These
	     entitlements raise the limit and give a large virtual address space. -->
	<key>com.apple.developer.kernel.increased-memory-limit</key>
	<true/>
	<key>com.apple.developer.kernel.extended-virtual-addressing</key>
	<true/>
</dict>
</plist>
